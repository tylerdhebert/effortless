{
  "name": "effortless",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first desktop app for coordinating agent efforts.",
  "author": "Tyler",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stable": "node scripts/dev-stable.mjs",
    "dev:playwright": "node scripts/dev-playwright.mjs",
    "capture:electron": "node scripts/capture-electron-shot.mjs",
    "build": "tsc && vite build && bun run build:cli && electron-builder",
    "build:cli": "node scripts/build-cli.mjs",
    "efl": "cmd /c efl.cmd",
    "seed": "cmd /c seed.cmd",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "bin": {
    "efl": "./efl.cmd"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^0.460.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-diff-view": "^3.3.3",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "icon-gen": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
